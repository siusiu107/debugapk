+++ b/app/src/main/java/com/siustudio/detoxlock/ShortFormPlatformDecision.kt
@@ -0,0 +1,19 @@
+package com.siustudio.detoxlock
+
+/** Pure per-platform decision used to prove that usage/rules never leak across platforms. */
+object ShortFormPlatformDecision {
+    data class Rule(
+        val enabled: Boolean,
+        val alwaysBlock: Boolean,
+        val timeLimitEnabled: Boolean,
+        val limitMs: Long,
+        val usedMs: Long,
+        val windowActive: Boolean
+    )
+
+    fun limitExceeded(rule: Rule): Boolean =
+        rule.enabled && rule.timeLimitEnabled && rule.usedMs >= rule.limitMs.coerceAtLeast(1L)
+
+    fun shouldBlock(rule: Rule): Boolean =
+        rule.enabled && (rule.alwaysBlock || rule.windowActive || limitExceeded(rule))
+}
