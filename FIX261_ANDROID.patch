@@ -0,0 +1,132 @@
+package com.siustudio.detoxlock
+
+import android.content.Context
+import android.content.Intent
+import android.os.Bundle
+import android.view.View
+import androidx.appcompat.app.AppCompatActivity
+import com.siustudio.detoxlock.databinding.ActivityAppLimitBlockedBinding
+
+/** Clean, single-instance notice used by every protected system-surface route. */
+class ProtectionNoticeActivity : AppCompatActivity() {
+    private lateinit var b: ActivityAppLimitBlockedBinding
+    private var noticeToken: String = ""
+    private var kind: ProtectionNoticeKind = ProtectionNoticeKind.ACCESSIBILITY
+    private var dismissed: Boolean = false
+
+    override fun onCreate(savedInstanceState: Bundle?) {
+        super.onCreate(savedInstanceState)
+        RemoteSafetyGate.syncAsync(this)
+        if (RemoteSafetyGate.finishIfDisabled(this)) {
+            releaseReservation(intent)
+            return
+        }
+        if (ProtectionRuntimePolicy.isUserFacingPaused(this)) {
+            releaseReservation(intent)
+            finish()
+            return
+        }
+
+        b = ActivityAppLimitBlockedBinding.inflate(layoutInflater)
+        setContentView(b.root)
+        SystemBarSafeArea.keepContentInsideSystemBars(this)
+        bindIntent(intent)
+        b.btnHome.text = "확인"
+        b.btnHome.setOnClickListener { dismissNotice() }
+    }
+
+    override fun onNewIntent(intent: Intent?) {
+        super.onNewIntent(intent)
+        if (intent != null) {
+            setIntent(intent)
+            bindIntent(intent)
+        }
+    }
+
+    private fun bindIntent(intent: Intent?) {
+        noticeToken = intent?.getStringExtra(EXTRA_TOKEN).orEmpty()
+        kind = runCatching {
+            ProtectionNoticeKind.valueOf(intent?.getStringExtra(EXTRA_KIND).orEmpty())
+        }.getOrDefault(ProtectionNoticeKind.ACCESSIBILITY)
+        if (RemoteSafetyGate.isMasterStopActive(this) || ProtectionRuntimePolicy.isUserFacingPaused(this)) {
+            ProtectionNoticeLaunchGate.releaseFailed(noticeToken)
+            finish()
+            return
+        }
+        if (noticeToken.isBlank() || !ProtectionNoticeLaunchGate.isReserved(noticeToken)) {
+            finish()
+            return
+        }
+        dismissed = false
+        b.root.visibility = View.VISIBLE
+        b.btnHome.isEnabled = true
+        CriticalSettingsOverlay.hideFullIfKey(
+            "protection_notice_fallback:$noticeToken",
+            force = true
+        )
+        ProtectionNoticeLaunchGate.markVisible(noticeToken)
+        val copy = ProtectionNoticeText.forKind(kind)
+        b.tvReason.text = copy.badge
+        b.tvTitle.text = copy.title
+        b.tvSub.text = copy.subtitle
+        b.tvDetail.text = copy.detail
+    }
+
+    private fun dismissNotice() {
+        if (dismissed) return
+        dismissed = true
+        b.btnHome.isEnabled = false
+        b.root.visibility = View.GONE
+        ProtectionNoticeLaunchGate.markDismissed(noticeToken, kind)
+        // Hide synchronously so even an OEM-delayed task removal cannot leave the
+        // confirmed card visible. finish() is idempotent and is kept as a fallback.
+        runCatching { finishAndRemoveTask() }
+        if (!isFinishing) finish()
+    }
+
+    private fun releaseReservation(intent: Intent?) {
+        val token = intent?.getStringExtra(EXTRA_TOKEN).orEmpty()
+        if (token.isNotBlank()) ProtectionNoticeLaunchGate.releaseFailed(token)
+    }
+
+    override fun onDestroy() {
+        if (!isChangingConfigurations && !dismissed && noticeToken.isNotBlank()) {
+            ProtectionNoticeLaunchGate.markDismissed(noticeToken, kind)
+        }
+        super.onDestroy()
+    }
+
+    @Deprecated("Deprecated in Java")
+    override fun onBackPressed() = dismissNotice()
+
+    companion object {
+        private const val EXTRA_KIND = "protection_notice_kind"
+        private const val EXTRA_TOKEN = "protection_notice_token"
+
+        fun launchReserved(context: Context, kind: ProtectionNoticeKind, token: String): Boolean {
+            if (!ProtectionNoticeLaunchGate.isReserved(token)) return false
+            val intent = Intent(context, ProtectionNoticeActivity::class.java).apply {
+                putExtra(EXTRA_KIND, kind.name)
+                putExtra(EXTRA_TOKEN, token)
+                addFlags(
+                    Intent.FLAG_ACTIVITY_NEW_TASK or
+                        Intent.FLAG_ACTIVITY_CLEAR_TOP or
+                        Intent.FLAG_ACTIVITY_SINGLE_TOP or
+                        Intent.FLAG_ACTIVITY_EXCLUDE_FROM_RECENTS
+                )
+            }
+            return runCatching {
+                context.startActivity(intent)
+                true
+            }.getOrElse {
+                ProtectionNoticeLaunchGate.releaseFailed(token)
+                false
+            }
+        }
+
+        fun showNow(context: Context, kind: ProtectionNoticeKind, token: String): Boolean {
+            if (!ProtectionNoticeLaunchGate.tryReserve(token)) return false
+            return launchReserved(context, kind, token)
+        }
+    }
+}
