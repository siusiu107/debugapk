+package com.siustudio.detoxlock
+
+/** User-facing, one-shot notices shown after a protected system screen is closed. */
+enum class ProtectionNoticeKind {
+    ACCESSIBILITY,
+    OVERLAY_PERMISSION,
+    SAFE_MODE,
+    APP_DELETE,
+    DEVICE_ADMIN,
+    VPN
+}
+
+data class ProtectionNoticeCopy(
+    val badge: String,
+    val title: String,
+    val subtitle: String,
+    val detail: String
+)
+
+object ProtectionNoticeText {
+    fun forKind(kind: ProtectionNoticeKind): ProtectionNoticeCopy = when (kind) {
+        ProtectionNoticeKind.ACCESSIBILITY -> ProtectionNoticeCopy(
+            badge = "접근성 보호",
+            title = "접근성 변경을 차단했어요",
+            subtitle = "보호가 적용 중인 동안에는 DetoxLock 접근성을 끌 수 없어요.",
+            detail = "접근성 끄기와 접근성 설정 전체 초기화 화면에서 뒤로 이동했습니다. 일반 접근성 설정은 그대로 사용할 수 있어요."
+        )
+        ProtectionNoticeKind.OVERLAY_PERMISSION -> ProtectionNoticeCopy(
+            badge = "권한 보호",
+            title = "다른 앱 위에 표시 변경을 차단했어요",
+            subtitle = "보호 화면에 필요한 권한은 실행 중에 해제할 수 없어요.",
+            detail = "해당 설정 화면에서 뒤로 이동했습니다. 다른 앱의 일반 설정에는 영향을 주지 않아요."
+        )
+        ProtectionNoticeKind.SAFE_MODE -> ProtectionNoticeCopy(
+            badge = "시스템 보호",
+            title = "안전모드 진입을 차단했어요",
+            subtitle = "현재 잠금 또는 제한을 우회하는 안전모드 진입은 사용할 수 없어요.",
+            detail = "실제 시스템 전원 메뉴의 안전모드 화면을 확인한 뒤 빠르게 두 번 뒤로 이동했습니다."
+        )
+        ProtectionNoticeKind.APP_DELETE -> ProtectionNoticeCopy(
+            badge = "앱 보호",
+            title = "앱 삭제를 차단했어요",
+            subtitle = "보호가 적용 중인 동안에는 DetoxLock을 삭제하거나 데이터를 지울 수 없어요.",
+            detail = "삭제 또는 데이터 제거 화면에서 뒤로 이동했습니다. 삭제가 필요하면 DetoxLock 안의 삭제 준비 절차를 이용해주세요."
+        )
+        ProtectionNoticeKind.DEVICE_ADMIN -> ProtectionNoticeCopy(
+            badge = "관리자 보호",
+            title = "기기 관리자 변경을 차단했어요",
+            subtitle = "보호가 적용 중인 동안에는 DetoxLock 관리자 권한을 끌 수 없어요.",
+            detail = "기기 관리자 해제 화면에서 뒤로 이동했습니다. 권한 해제가 필요하면 앱 안의 안내 절차를 이용해주세요."
+        )
+        ProtectionNoticeKind.VPN -> ProtectionNoticeCopy(
+            badge = "VPN 보호",
+            title = "VPN 변경을 차단했어요",
+            subtitle = "차단에 사용 중인 VPN은 보호가 끝나기 전까지 해제할 수 없어요.",
+            detail = "VPN 해제 화면에서 뒤로 이동하고 필요한 보호 연결을 다시 확인했습니다."
+        )
+    }
+}
+
+data class ProtectionBackPlan(
+    val backCount: Int,
+    val backIntervalMs: Long,
+    val noticeDelayMs: Long
+)
+
+/** One protected surface owns one bounded BACK sequence and one notice launch. */
+object ProtectionRoutePlan {
+    fun forKind(kind: ProtectionNoticeKind): ProtectionBackPlan = when (kind) {
+        ProtectionNoticeKind.SAFE_MODE -> ProtectionBackPlan(
+            backCount = 2,
+            backIntervalMs = 55L,
+            noticeDelayMs = 125L
+        )
+        else -> ProtectionBackPlan(
+            backCount = 1,
+            backIntervalMs = 0L,
+            noticeDelayMs = 220L
+        )
+    }
+}
+
+/**
+ * Process-local launch ownership. One protected surface entry may create at most one
+ * notice. The same token stays consumed after dismissal so stale Accessibility events
+ * cannot immediately reopen the Activity; a new window/click entry receives a new token.
+ */
+object ProtectionNoticeLaunchGate {
+    private var reservedToken: String? = null
+    private var lastHandledToken: String? = null
+    private var passiveSuppressedKind: ProtectionNoticeKind? = null
+    private var pending: Boolean = false
+    private var visible: Boolean = false
+
+    @Synchronized
+    fun tryReserve(token: String): Boolean {
+        if (token.isBlank() || token == lastHandledToken || pending || visible) return false
+        reservedToken = token
+        lastHandledToken = token
+        pending = true
+        visible = false
+        return true
+    }
+
+    @Synchronized
+    fun isReserved(token: String): Boolean = reservedToken == token && (pending || visible)
+
+    @Synchronized
+    fun isPending(token: String): Boolean = reservedToken == token && pending
+
+    @Synchronized
+    fun markVisible(token: String) {
+        if (reservedToken != token) return
+        pending = false
+        visible = true
+    }
+
+    @Synchronized
+    fun markDismissed(token: String, kind: ProtectionNoticeKind) {
+        if (reservedToken == token) {
+            reservedToken = null
+            pending = false
+            visible = false
+            // Finishing our Activity exposes the Settings page that was immediately
+            // below it and creates another WINDOW_STATE_CHANGED event. Keep that
+            // passive hand-off from opening the same notice again. A real click on a
+            // system surface clears this latch before the next protection decision.
+            passiveSuppressedKind = kind
+        }
+    }
+
+    @Synchronized
+    fun shouldSuppressPassiveReentry(kind: ProtectionNoticeKind): Boolean =
+        passiveSuppressedKind == kind
+
+    @Synchronized
+    fun noteExternalInteraction() {
+        passiveSuppressedKind = null
+    }
+
+    @Synchronized
+    fun releaseFailed(token: String) {
+        if (reservedToken != token) return
+        reservedToken = null
+        pending = false
+        visible = false
+        if (lastHandledToken == token) lastHandledToken = null
+    }
+
+    @Synchronized
+    fun clear() {
+        reservedToken = null
+        lastHandledToken = null
+        passiveSuppressedKind = null
+        pending = false
+        visible = false
+    }
+}
