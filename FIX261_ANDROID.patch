+package com.siustudio.detoxlock
+
+import android.view.LayoutInflater
+import android.view.ViewGroup
+import androidx.recyclerview.widget.RecyclerView
+import com.siustudio.detoxlock.databinding.RowShortFormPlatformBinding
+
+class ShortFormPlatformAdapter(
+    private val onEnabledChanged: (ShortFormPolicy.Platform, Boolean) -> Unit,
+    private val onDailyLimit: (ShortFormPolicy.Platform) -> Unit,
+    private val onTimeWindow: (ShortFormPolicy.Platform) -> Unit
+) : RecyclerView.Adapter<ShortFormPlatformAdapter.Holder>() {
+
+    data class Row(
+        val platform: ShortFormPolicy.Platform,
+        val enabled: Boolean,
+        val summary: String,
+        val editable: Boolean
+    )
+
+    private var rows: List<Row> = emptyList()
+
+    inner class Holder(val binding: RowShortFormPlatformBinding) :
+        RecyclerView.ViewHolder(binding.root)
+
+    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): Holder = Holder(
+        RowShortFormPlatformBinding.inflate(LayoutInflater.from(parent.context), parent, false)
+    )
+
+    override fun getItemCount(): Int = rows.size
+
+    override fun onBindViewHolder(holder: Holder, position: Int) {
+        val row = rows[position]
+        with(holder.binding) {
+            swPlatform.setOnCheckedChangeListener(null)
+            swPlatform.text = row.platform.label
+            swPlatform.isChecked = row.enabled
+            swPlatform.isEnabled = row.editable
+            swPlatform.setOnCheckedChangeListener { _, checked ->
+                onEnabledChanged(row.platform, checked)
+            }
+            tvMeta.text = row.summary
+            btnDailyLimit.isEnabled = row.editable
+            btnTimeWindow.isEnabled = row.editable
+            btnDailyLimit.setOnClickListener { onDailyLimit(row.platform) }
+            btnTimeWindow.setOnClickListener { onTimeWindow(row.platform) }
+            root.alpha = if (row.editable) 1f else 0.58f
+            root.setOnClickListener { if (row.editable) onDailyLimit(row.platform) }
+        }
+    }
+
+    fun submit(value: List<Row>) {
+        rows = value
+        notifyDataSetChanged()
+    }
+}
