diff --git a/app/src/test/java/com/siustudio/detoxlock/ProtectionSurfacePoliciesTest.kt b/app/src/test/java/com/siustudio/detoxlock/ProtectionSurfacePoliciesTest.kt
index dfe93de..055ced2 100644
--- a/app/src/test/java/com/siustudio/detoxlock/ProtectionSurfacePoliciesTest.kt
+++ b/app/src/test/java/com/siustudio/detoxlock/ProtectionSurfacePoliciesTest.kt
@@ -1,10 +1,103 @@
 package com.siustudio.detoxlock
 
+import org.junit.Assert.assertEquals
 import org.junit.Assert.assertFalse
 import org.junit.Assert.assertTrue
 import org.junit.Test
 
 class ProtectionSurfacePoliciesTest {
+
+    @Test
+    fun protectionNoticeLaunchesOncePerSurfaceEntry() {
+        ProtectionNoticeLaunchGate.clear()
+        assertTrue(ProtectionNoticeLaunchGate.tryReserve("ACCESSIBILITY:10"))
+        assertFalse(ProtectionNoticeLaunchGate.tryReserve("ACCESSIBILITY:10"))
+        assertFalse(ProtectionNoticeLaunchGate.tryReserve("APP_DELETE:11"))
+        ProtectionNoticeLaunchGate.markVisible("ACCESSIBILITY:10")
+        ProtectionNoticeLaunchGate.markDismissed("ACCESSIBILITY:10", ProtectionNoticeKind.ACCESSIBILITY)
+        assertTrue(ProtectionNoticeLaunchGate.shouldSuppressPassiveReentry(ProtectionNoticeKind.ACCESSIBILITY))
+        assertFalse(ProtectionNoticeLaunchGate.shouldSuppressPassiveReentry(ProtectionNoticeKind.APP_DELETE))
+        ProtectionNoticeLaunchGate.noteExternalInteraction()
+        assertFalse(ProtectionNoticeLaunchGate.shouldSuppressPassiveReentry(ProtectionNoticeKind.ACCESSIBILITY))
+
+        // Stale content events from the same Settings entry stay consumed, while a
+        // new window/click sequence can show its own notice.
+        assertFalse(ProtectionNoticeLaunchGate.tryReserve("ACCESSIBILITY:10"))
+        assertTrue(ProtectionNoticeLaunchGate.tryReserve("APP_DELETE:11"))
+        ProtectionNoticeLaunchGate.releaseFailed("APP_DELETE:11")
+        assertTrue(ProtectionNoticeLaunchGate.tryReserve("APP_DELETE:11"))
+        ProtectionNoticeLaunchGate.markDismissed("APP_DELETE:11", ProtectionNoticeKind.APP_DELETE)
+        ProtectionNoticeLaunchGate.clear()
+    }
+
+    @Test
+    fun protectionNoticesHaveDistinctConciseCopy() {
+        val kinds = listOf(
+            ProtectionNoticeKind.ACCESSIBILITY,
+            ProtectionNoticeKind.OVERLAY_PERMISSION,
+            ProtectionNoticeKind.SAFE_MODE,
+            ProtectionNoticeKind.APP_DELETE
+        )
+        val copies = kinds.map(ProtectionNoticeText::forKind)
+        assertEquals(kinds.size, copies.map { it.title }.toSet().size)
+        assertTrue(copies.all { it.badge.isNotBlank() && it.subtitle.isNotBlank() && it.detail.isNotBlank() })
+    }
+
+    @Test
+    fun safeModeOwnsExactlyTwoFastBackActions() {
+        val safe = ProtectionRoutePlan.forKind(ProtectionNoticeKind.SAFE_MODE)
+        assertEquals(2, safe.backCount)
+        assertTrue(safe.backIntervalMs in 1L..100L)
+        assertTrue(safe.noticeDelayMs > safe.backIntervalMs)
+        assertEquals(1, ProtectionRoutePlan.forKind(ProtectionNoticeKind.ACCESSIBILITY).backCount)
+        assertEquals(1, ProtectionRoutePlan.forKind(ProtectionNoticeKind.APP_DELETE).backCount)
+    }
+
+    @Test
+    fun accessibilityProtectionNeverCapturesAnotherAppsRowOrDetail() {
+        val list = AccessibilityTargetIsolationPolicy.Evidence(
+            listSurface = true,
+            clickedExactSelf = false,
+            detailSurface = false,
+            exactSelfTitle = false,
+            armedFromSelfClick = false,
+            interactiveOffAction = false
+        )
+        assertFalse(AccessibilityTargetIsolationPolicy.shouldBlockList(list))
+        assertTrue(AccessibilityTargetIsolationPolicy.shouldBlockList(list.copy(clickedExactSelf = true)))
+
+        val otherAppDetail = list.copy(
+            listSurface = false,
+            detailSurface = true,
+            interactiveOffAction = true
+        )
+        assertFalse(AccessibilityTargetIsolationPolicy.shouldBlockDetail(otherAppDetail))
+        assertTrue(AccessibilityTargetIsolationPolicy.shouldBlockDetail(
+            otherAppDetail.copy(exactSelfTitle = true)
+        ))
+        assertTrue(AccessibilityTargetIsolationPolicy.shouldBlockDetail(
+            otherAppDetail.copy(armedFromSelfClick = true)
+        ))
+    }
+
+    @Test
+    fun shortFormDailyAndWindowRulesStayIndependentPerPlatform() {
+        val shorts = ShortFormPlatformDecision.Rule(
+            enabled = true,
+            alwaysBlock = false,
+            timeLimitEnabled = true,
+            limitMs = 10 * 60_000L,
+            usedMs = 11 * 60_000L,
+            windowActive = false
+        )
+        val reels = shorts.copy(usedMs = 2 * 60_000L)
+        val tikTok = reels.copy(timeLimitEnabled = false, windowActive = true)
+
+        assertTrue(ShortFormPlatformDecision.shouldBlock(shorts))
+        assertFalse(ShortFormPlatformDecision.shouldBlock(reels))
+        assertTrue(ShortFormPlatformDecision.shouldBlock(tikTok))
+        assertFalse(ShortFormPlatformDecision.shouldBlock(tikTok.copy(windowActive = false)))
+    }
     @Test
     fun appPinningBlocksEveryPinnedAppOnlyDuringBypassProtection() {
         assertFalse(AppPinningBlockPolicy.isUserScreenPinning(0))
