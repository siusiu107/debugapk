+package com.siustudio.detoxlock
+
+/** Pure target-isolation rules for Accessibility settings protection. */
+object AccessibilityTargetIsolationPolicy {
+    data class Evidence(
+        val listSurface: Boolean,
+        val clickedExactSelf: Boolean,
+        val detailSurface: Boolean,
+        val exactSelfTitle: Boolean,
+        val armedFromSelfClick: Boolean,
+        val interactiveOffAction: Boolean
+    )
+
+    /** A list remains usable; only the actual DetoxLock row click is routed back. */
+    fun shouldBlockList(evidence: Evidence): Boolean =
+        evidence.listSurface && evidence.clickedExactSelf
+
+    /** Another app's detail screen can never inherit protection from words elsewhere. */
+    fun shouldBlockDetail(evidence: Evidence): Boolean =
+        evidence.interactiveOffAction && evidence.detailSurface &&
+            (evidence.exactSelfTitle || evidence.armedFromSelfClick)
+}
